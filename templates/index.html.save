<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>5G Dashboard | CoreControl Pro</title>
    <meta name="description" content="Real-time 5G network monitoring and control dashboard for gNB and UE management.">
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>

<body>

    <!-- TOP NAVIGATION -->
    <nav class="navbar">
        <div class="nav-brand">
            <div class="brand-logo">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 20V4l6 4 6-4v16"/><path d="M6 12h12"/></svg>
            </div>
            <span>CoreControl <span class="brand-accent">Pro</span></span>
        </div>
        <div class="nav-center">
            <div class="network-pulse-bar">
                <div class="pulse-dot"></div>
                <span id="network-status-label">Network Active — 5G NR Sub-6GHz</span>
            </div>
        </div>
        <div class="nav-actions">
            <div class="nav-time" id="nav-clock"></div>
            <button class="nav-btn" id="sync-btn" onclick="loadNodes()">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
                Sync
            </button>
        </div>
    </nav>

    <!-- ACTION RIBBON -->
    <div class="action-ribbon">
        <div class="ribbon-container">
            <div class="ribbon-group">
                <span class="ribbon-label">Radio Access Network</span>
                <div class="ribbon-buttons">
                    <button class="btn-primary" id="deploy-gnb-btn" onclick="startGNB()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                        Deploy gNB
                    </button>
                    <button class="btn-danger" id="stop-gnb-btn" onclick="stopGNB()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="12" height="12" x="6" y="6" rx="2" ry="2"/></svg>
                        Power Down
                    </button>
                </div>
            </div>

            <div class="ribbon-divider"></div>

            <div class="ribbon-group">
                <span class="ribbon-label">User Equipment</span>
                <div class="ribbon-buttons">
                    <button class="btn-primary" id="connect-ue-btn" onclick="startUE()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                        Connect UE
                    </button>
                    <button class="btn-danger" id="disconnect-ue-btn" onclick="stopUE()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect width="12" height="12" x="6" y="6" rx="2" ry="2"/></svg>
                        Disconnect UE
                    </button>
                </div>
            </div>

            <div class="ribbon-divider"></div>

            <div class="ribbon-group">
                <span class="ribbon-label">5G Core</span>
                <div class="ribbon-buttons">
                    <button class="btn-secondary" id="core-health-btn" onclick="checkCoreHealth()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        Core Health
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN DASHBOARD -->
    <main class="dashboard-wrapper">

        <!-- KPI STATS ROW -->
        <div class="kpi-grid" id="kpi-grid">
            <div class="kpi-card" id="kpi-latency">
                <div class="kpi-icon" style="--kpi-color: #2979FF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="kpi-data">
                    <span class="kpi-label">E2E Latency</span>
                    <span class="kpi-value" id="kpi-val-latency">—</span>
                    <span class="kpi-unit">ms</span>
                </div>
                <div class="kpi-trend up" id="kpi-trend-latency">▼ 12%</div>
            </div>
            <div class="kpi-card" id="kpi-throughput">
                <div class="kpi-icon" style="--kpi-color: #00E676;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </div>
                <div class="kpi-data">
                    <span class="kpi-label">Throughput</span>
                    <span class="kpi-value" id="kpi-val-throughput">—</span>
                    <span class="kpi-unit">Mbps</span>
                </div>
                <div class="kpi-trend up" id="kpi-trend-throughput">▲ 8%</div>
            </div>
            <div class="kpi-card" id="kpi-ues">
                <div class="kpi-icon" style="--kpi-color: #B388FF;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="kpi-data">
                    <span class="kpi-label">Connected UEs</span>
                    <span class="kpi-value" id="kpi-val-ues">—</span>
                    <span class="kpi-unit">devices</span>
                </div>
                <div class="kpi-trend neutral" id="kpi-trend-ues">● Stable</div>
            </div>
            <div class="kpi-card" id="kpi-signal">
                <div class="kpi-icon" style="--kpi-color: #FF6D00;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
                </div>
                <div class="kpi-data">
                    <span class="kpi-label">Signal Strength</span>
                    <span class="kpi-value" id="kpi-val-signal">—</span>
                    <span class="kpi-unit">dBm</span>
                </div>
                <div class="kpi-trend up" id="kpi-trend-signal">▲ Good</div>
            </div>
        </div>

        <!-- SECTION LABEL -->
        <div class="section-label">
            <span>Network Status</span>
            <div class="section-line"></div>
        </div>

        <!-- NODES + TRUST GRID -->
        <div class="dash-grid">

            <!-- Nodes Status Card -->
            <div class="dash-card">
                <div class="dash-card-header">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" style="margin-right:8px;"><rect width="6" height="6" x="9" y="2" rx="1"/><rect width="6" height="6" x="2" y="16" rx="1"/><rect width="6" height="6" x="16" y="16" rx="1"/><path d="M12 8v4"/><path d="M12 12H5v4"/><path d="M12 12h7v4"/></svg>
                        System Nodes
                    </h3>
                    <span class="status-indicator live">
                        <span class="pulse-ring"></span>Live
                    </span>
                </div>
                <div class="dash-card-body">
                    <div id="nodes" class="nodes-content">Loading...</div>
                </div>
            </div>

            <!-- Trust Score Card -->
            <div class="dash-card">
                <div class="dash-card-header">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" style="margin-right:8px;"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2-1 4-2 7-2 2.89 0 4.7 1.14 6.81 2a1 1 0 0 1 .5.92Z"/><path d="M12 22V2"/></svg>
                        Security Trust Score
                    </h3>
                    <button class="btn-sm-secondary" onclick="loadTrust()">Refresh</button>
                </div>
                <div class="dash-card-body trust-container" id="trust-container">
                    <div class="score-ring-wrap">
                        <svg class="score-ring-svg" viewBox="0 0 120 120" width="120" height="120">
                            <circle class="score-ring-bg" cx="60" cy="60" r="50" />
                            <circle class="score-ring-fg" id="score-ring-fg" cx="60" cy="60" r="50" stroke-dasharray="314" stroke-dashoffset="314"/>
                        </svg>
                        <div class="score-ring-label">
                            <span class="score-value" id="score-value">--</span>
                            <span class="score-pct">%</span>
                        </div>
                    </div>
                    <div class="score-details" id="score-details">Loading...</div>
                </div>
            </div>

            <!-- Network Topology Mini-Map -->
            <div class="dash-card topology-card">
                <div class="dash-card-header">
                    <h3>
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" style="margin-right:8px;"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>
                        Topology Map
                    </h3>
                    <span class="badge-blue">5G NR</span>
                </div>
                <div class="dash-card-body">
                    <canvas id="topology-canvas" width="320" height="180"></canvas>
                </div>
            </div>

        </div>

        <!-- SECTION LABEL -->
        <div class="section-label">
            <span>Live Telemetry</span>
            <div class="section-line"></div>
        </div>

        <!-- CHARTS ROW -->
        <div class="charts-grid">
            <div class="dash-card chart-card">
                <div class="dash-card-header">
                    <h3>Throughput (Mbps)</h3>
                    <span class="chart-range-label">Live / 60s</span>
                </div>
                <div class="dash-card-body chart-body">
                    <canvas id="chart-throughput" height="120"></canvas>
                </div>
            </div>
            <div class="dash-card chart-card">
                <div class="dash-card-header">
                    <h3>Latency (ms)</h3>
                    <span class="chart-range-label">Live / 60s</span>
                </div>
                <div class="dash-card-body chart-body">
                    <canvas id="chart-latency" height="120"></canvas>
                </div>
            </div>
        </div>

        <!-- SECTION LABEL -->
        <div class="section-label">
            <span>Event Stream</span>
            <div class="section-line"></div>
        </div>

        <!-- Event Logs Panel -->
        <div class="dash-panel">
            <div class="dash-card-header">
                <h3>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" style="margin-right:8px;"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Event Stream
                </h3>
                <div style="display:flex;gap:12px;align-items:center;">
                    <label class="toggle-wrap" title="Auto-scroll">
                        <input type="checkbox" id="autoscroll-toggle" checked>
                        <span class="toggle-slider"></span>
                        <span class="toggle-label">Auto-scroll</span>
                    </label>
                    <button class="btn-sm-ghost" onclick="clearLogs()">Clear</button>
                </div>
            </div>
            <div class="log-container" id="log-container">
                <div id="logs-list"></div>
            </div>
        </div>

    </main>

    <div id="toast-container"></div>

    
</body>

</html>
